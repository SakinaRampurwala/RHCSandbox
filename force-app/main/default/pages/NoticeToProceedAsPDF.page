<apex:page controller="NoticeToProceedCtrl" action="{!initPdf}" renderAs="pdf" sidebar="false" showHeader="false" applyHtmlTag="false" applyBodyTag="false" standardStylesheets="false">
    <html>
    <head>
        <style type="text/css">
            @page {
                margin: 0.4in;
                size: letter;
            }
            body {
                font-family: "Times New Roman", Times, serif;
                font-size: 12pt;
                color: #000;
                line-height: 1.25;
            }
            .header-logo {
                width: 190px;
                max-width: 100%;
                height: auto;
                margin-bottom: 10px;
            }
            .doc-sub-title {
                text-align: center;
                font-size: 15pt;
                font-weight: bold;
            }
            .doc-title {
                text-align: center;
                font-size: 17pt;
                font-weight: bold;
                margin: 6px 0 10px;
            }
            table {
                width: 100%;
                border-collapse: collapse;
                font-size: 11pt;
                table-layout: fixed;
            }
            td {
                border: 1px solid #000;
                padding: 4px 6px;
                vertical-align: top;
            }
            .label-cell {
                font-weight: bold;
            }
            .paragraph-cell {
                line-height: 1.25;
                padding: 8px 6px;
            }
            .empty-row td {
                height: 12px;
                padding: 0;
            }
            .signature-wrap {
                margin-top: 12px;
                padding: 8px 8px 12px;
            }
            .signature-title {
                font-weight: bold;
                margin-bottom: 4px;
            }
            .signature-line {
                margin-top: 10px;
            }
            .date-label {
                font-weight: bold;
                margin-right: 8px;
            }
            .line {
                display: inline-block;
                border-bottom: 1px solid #000;
                min-width: 240px;
                margin: 0;
                padding-bottom: 1px;
            }
            .signature-image {
                width: 100%;
                height: 100%;
                display: block;
            }
            .signature-box {
                height: 110px;
                border: 1px solid #000;
                padding: 6px;
                box-sizing: border-box;
                width: 100%;
                overflow: hidden;
                line-height: 0;
            }
        </style>
    </head>
    <body>
        <apex:image value="{!logoUrl}" rendered="{!logoUrl != null}" styleClass="header-logo"/>

        <div class="doc-sub-title">Home Improvement Program</div>
        <div class="doc-title">NOTICE TO PROCEED</div>

        <table cellspacing="0" cellpadding="0">
            <colgroup>
                <col style="width: 28%;" />
                <col style="width: 42%;" />
                <col style="width: 16%;" />
                <col style="width: 14%;" />
            </colgroup>
            <tr>
                <td class="label-cell">Project Location:</td>
                <td>{!vfNoticeData.projectLocation}</td>
                <td class="label-cell">Case No.</td>
                <td>{!vfNoticeData.caseNumber}</td>
            </tr>
            <tr>
                <td class="label-cell">Property Owner:</td>
                <td colspan="3">{!vfNoticeData.propertyOwner}</td>
            </tr>
            <tr class="empty-row">
                <td colspan="4"></td>
            </tr>
            <tr>
                <td class="label-cell">Contractor:</td>
                <td>{!vfNoticeData.contractor}</td>
                <td class="label-cell">Telephone:</td>
                <td>{!vfNoticeData.telephone}</td>
            </tr>
            <tr>
                <td class="label-cell">Address:</td>
                <td colspan="3">{!vfNoticeData.contractorAddress}</td>
            </tr>
            <tr>
                <td class="label-cell">Contract Dated:</td>
                <td colspan="3">{!vfNoticeData.contractDated}</td>
            </tr>
            <tr>
                <td colspan="4" class="paragraph-cell">
                    You are hereby authorized to proceed with the work listed in our Construction Contract. We have agreed that you will begin work and complete all improvements within the time periods listed below. It is understood that failure to complete this work in a timely manner may be grounds for termination of our contract.
                </td>
            </tr>
            <tr>
                <td colspan="2">All work will begin not later than this date:</td>
                <td colspan="2">{!vfNoticeData.projectedStartDate}</td>
            </tr>
            <tr>
                <td colspan="2">All work will be completed not later than this date:</td>
                <td colspan="2">{!vfNoticeData.projectedCompletionDate}</td>
            </tr>
            <tr>
                <td colspan="4" class="paragraph-cell">
                    According to the terms of our contract, progress payments can be made for work items that are completed in place. Such payments will be considered after receipt of your written claim subject to inspection by the Rehabilitation Specialist and approval by the grantee or its designee.
                </td>
            </tr>
            <tr>
                <td colspan="4" class="paragraph-cell">
                    No deviation from the Work Write-up will be permitted without specific authorization and a Change Order which must be approved by the grantee. It is understood that changes will generally not be considered except for unforeseen problems that must be addressed in order to complete work items included in this project.
                </td>
            </tr>
        </table>

        <div class="signature-wrap">
            <div class="signature-title">Signed:</div>
            <div class="signature-box">
                <apex:image value="{!vfImgUrl}" rendered="{!NOT(ISBLANK(vfImgUrl))}" styleClass="signature-image"/>
            </div>
            <div class="signature-line">
                <span class="date-label">Date:</span>
                <span class="line">{!currentRecordDate}</span>
            </div>
        </div>
    </body>
    </html>
</apex:page>
