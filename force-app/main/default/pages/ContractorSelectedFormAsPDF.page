<apex:page controller="ContractorSelectedFormLwcCtrl" action="{!initPdf}" renderAs="pdf" sidebar="false" showHeader="false" applyHtmlTag="false" applyBodyTag="false" standardStylesheets="false">
    <html>
    <head>
        <style type="text/css">
            @page {
                margin: 0.35in;
                size: letter;
            }
            body {
                font-family: 'Times New Roman', Times, serif;
                font-size: 13px;
                color: #193247;
                line-height: 1.45;
                margin: 0;
                padding: 0;
            }
            .page-shell {
                background: #f3f5f8;
                border: 1px solid #d7dfe8;
                padding: 10px;
            }
            .form-card {
                border: 1px solid #d7dfe8;
                padding: 18px 20px 24px;
                background: #ffffff;
            }
            .program-title {
                text-align: center;
                font-size: 19px;
                font-weight: bold;
                color: #12344d;
            }
            .document-title {
                margin-top: 6px;
                text-align: center;
                font-size: 24px;
                font-weight: bold;
                color: #1f3f58;
                padding-bottom: 8px;
            }
            .header-table,
            .field-table,
            .bid-table,
            .signature-meta {
                width: 100%;
                border-collapse: collapse;
            }
            .header-table {
                margin-top: 18px;
            }
            .header-table td {
                vertical-align: middle;
            }
            .header-meta {
                width: 60%;
                font-size: 15px;
                font-weight: bold;
            }
            .logo-cell {
                width: 40%;
                text-align: right;
            }
            .logo-cell img {
                width: auto;
                height: 35px;
                max-width: 110px;
            }
            .field-table {
                margin-top: 18px;
            }
            .field-table td {
                border: 1px solid #d6dbe1;
                background: #fafbfc;
                padding: 10px 12px;
                vertical-align: top;
            }
            .field-label {
                display: block;
                font-size: 11px;
                font-weight: bold;
                text-transform: uppercase;
                letter-spacing: 0.05em;
                color: #536b80;
            }
            .field-value {
                display: block;
                margin-top: 5px;
                min-height: 14px;
                font-size: 14px;
                color: #102435;
            }
            .bid-table {
                margin-top: 18px;
                table-layout: fixed;
            }
            .bid-table th,
            .bid-table td {
                border: 1px solid #bfc9d4;
                padding: 10px 9px;
                vertical-align: middle;
            }
            .bid-table th {
                background: #f1f4f7;
                color: #193247;
                font-size: 13px;
                font-weight: bold;
                text-align: left;
            }
            .center-cell {
                text-align: center;
                width: 90px;
            }
            .empty-state {
                text-align: center;
                color: #4b647a;
                background: #fbfcfd;
            }
            .legal-copy {
                margin-top: 18px;
                font-size: 14px;
                line-height: 1.6;
                color: #17334a;
            }
            .signature-section {
                margin-top: 12px;
                padding: 12px 14px 8px;
                border: 1px solid #d9e1ea;
                background: #f7f9fb;
                page-break-inside: avoid;
                break-inside: avoid;
            }
            .signature-panel {
                width: 100%;
                border-collapse: collapse;
                page-break-inside: avoid;
                break-inside: avoid;
            }
            .signature-panel td {
                padding: 0;
                page-break-inside: avoid;
                break-inside: avoid;
            }
            .signature-label {
                display: block;
                margin-bottom: 6px;
                font-size: 12px;
                font-weight: bold;
                text-transform: uppercase;
                letter-spacing: 0.06em;
                color: #26455e;
            }
            .signature-box {
                height: 135px;
                max-height: 135px;
                width: 100%;
                border: 1px solid #7590a8;
                background: #fff;
                vertical-align: bottom;
                overflow: hidden;
                line-height: 0;
                page-break-inside: avoid;
                break-inside: avoid;
            }
            .signature-box img {
                display: block;
                max-width: 100%;
                width: auto;
                height: 100%;
                margin: 0 auto;
            }
            .signature-meta {
                margin-top: 6px;
                table-layout: fixed;
                page-break-inside: avoid;
                break-inside: avoid;
            }
            .signature-meta td {
                font-size: 13px;
                font-weight: bold;
                color: #193247;
                padding: 0;
                vertical-align: top;
            }
            .signature-meta .name-cell {
                width: 50%;
                text-align: left;
            }
            .signature-meta .date-cell {
                width: 50%;
                text-align: right;
                white-space: nowrap;
            }
        </style>
    </head>
    <body>
        <div class="page-shell">
            <div class="form-card">
                <div class="program-title">Home Improvement Program</div>
                <div class="document-title">Bid Submittal and Contractor Selection Form</div>

                <table class="header-table">
                    <tr>
                        <td class="header-meta">Date: {!displayDate}</td>
                        <td class="logo-cell">
                            <apex:image value="{!logoUrl}" rendered="{!NOT(ISBLANK(logoUrl))}" />
                        </td>
                    </tr>
                </table>

                <table class="field-table">
                    <tr>
                        <td colspan="2">
                            <span class="field-label">Property Address</span>
                            <span class="field-value">{!propertyAddress}</span>
                        </td>
                        <td>
                            <span class="field-label">City/Town</span>
                            <span class="field-value">{!cityTown}</span>
                        </td>
                        <td>
                            <span class="field-label">Zip Code</span>
                            <span class="field-value">{!zipCode}</span>
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2">
                            <span class="field-label">Owner Name(s)</span>
                            <span class="field-value">{!ownerNames}</span>
                        </td>
                        <td>
                            <span class="field-label">Phone</span>
                            <span class="field-value">{!ownerPhone}</span>
                        </td>
                        <td>
                            <span class="field-label">Email</span>
                            <span class="field-value">{!ownerEmail}</span>
                        </td>
                    </tr>
                </table>

                <table class="bid-table">
                    <thead>
                        <tr>
                            <th>Contractor</th>
                            <th>Bid</th>
                            <th class="center-cell">Homeowner Selection "x"</th>
                            <th class="center-cell">Owner Initial(s)</th>
                            <th class="center-cell">Program Staff</th>
                        </tr>
                    </thead>
                    <tbody>
                        <apex:outputPanel rendered="{!hasPdfVendorRows}" layout="none">
                            <apex:repeat value="{!pdfVendorRows}" var="row">
                                <tr>
                                    <td>{!row.contractorName}</td>
                                    <td>{!row.bidAmount}</td>
                                    <td class="center-cell">{!row.selectionMark}</td>
                                    <td class="center-cell">{!row.homeownerInitials}</td>
                                    <td class="center-cell">{!row.programStaffInitials}</td>
                                </tr>
                            </apex:repeat>
                        </apex:outputPanel>
                        <apex:outputPanel rendered="{!NOT(hasPdfVendorRows)}" layout="none">
                            <tr>
                                <td colspan="5" class="empty-state">No contractor bids were found for this RFQ.</td>
                            </tr>
                        </apex:outputPanel>
                    </tbody>
                </table>

                <div class="legal-copy">
                    I/We have reviewed the bids for the work to be done at my/our property and understand that my/our initials above represent the choice that I/we have made for the contractor to be used for this project and have made this choice of my/our own will. I understand that the amount of my grant is based on the lowest reasonable bid and that I may choose a higher bidder by putting the monetary difference in an escrow account.
                </div>

                <table class="signature-panel">
                    <tr>
                        <td>
                            <div class="signature-section">
                                <span class="signature-label">Owner Signature(s)</span>
                                <div class="signature-box">
                                    <apex:image value="{!homeownerSignatureUrl}" rendered="{!hasHomeownerSignature}" />
                                </div>
                                <table class="signature-meta">
                                    <tr>
                                        <td class="name-cell">Owner Signature(s)</td>
                                        <td class="date-cell">Sign Date: {!homeownerSignDate}</td>
                                    </tr>
                                </table>
                            </div>
                        </td>
                    </tr>
                </table>

                <table class="signature-panel">
                    <tr>
                        <td>
                            <div class="signature-section">
                                <span class="signature-label">Program Representative Signature</span>
                                <div class="signature-box">
                                    <apex:image value="{!programStaffSignatureUrl}" rendered="{!hasProgramStaffSignature}" />
                                </div>
                                <table class="signature-meta">
                                    <tr>
                                        <td class="name-cell">Program Representative Signature</td>
                                        <td class="date-cell">Sign Date: {!programStaffSignDate}</td>
                                    </tr>
                                </table>
                            </div>
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </body>
    </html>
</apex:page>